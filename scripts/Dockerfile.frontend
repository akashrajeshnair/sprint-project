FROM python:3.12-slim

WORKDIR /app

COPY scripts/requirements.frontend.txt ./requirements.frontend.txt
RUN pip install --upgrade pip && pip install -r requirements.frontend.txt

COPY . .
COPY .env.docker ./.env

EXPOSE 8501

ENV STREAMLIT_PORT=8501 \
    API_BASE_URL=http://sprint-backend:8000

CMD ["python", "-m", "streamlit", "run", "streamlit_app.py", "--server.address", "0.0.0.0", "--server.port", "8501"]
